<!-- About Start -->
<div class="container-fluid py-2 about bg-light">
  <div class="container py-5">
    <div class="row g-5 align-items-center">
      <div class="col-lg-5 wow fadeIn" data-wow-delay="0.1s">
        <div class="video border">
          <button
            type="button"
            class="btn btn-play"
            data-bs-toggle="modal"
            data-src="/assets/video/main-video.mp4"
            data-bs-target="#videoModal"
          >
            <span></span>
          </button>
        </div>
      </div>
      <div class="col-lg-7 wow fadeIn" data-wow-delay="0.3s">
        <h4
          class="text-primary mb-4 border-bottom border-primary border-2 d-inline-block p-2 title-border-radius"
        >
          {{ "ABOUT_US_LABEL" | i18n }}
        </h4>
        <h1 class="text-dark mb-4 display-5">{{ "ABOUT_US_TITLE" | i18n }}</h1>
        <p class="text-dark mb-4">{{ "ABOUT_US_DESCRIPTION" | i18n }}</p>
        <div class="row mb-4">
          <div class="col-lg-6">
            <h6 class="mb-3">
              <i class="fas fa-check-circle me-2"></i>{{ "ABOUT_US_BULLET_1" | i18n }}
            </h6>
            <h6 class="mb-3">
              <i class="fas fa-check-circle me-2 text-primary"></i>{{ "ABOUT_US_BULLET_2" | i18n }}
            </h6>
            <h6 class="mb-3">
              <i class="fas fa-check-circle me-2 text-secondary"></i
              >{{ "ABOUT_US_BULLET_3" | i18n }}
            </h6>
            <h6><i class="fas fa-check-circle me-2"></i>{{ "ABOUT_US_BULLET_7" | i18n }}</h6>
          </div>
          <div class="col-lg-6">
            <h6 class="mb-3">
              <i class="fas fa-check-circle me-2"></i>{{ "ABOUT_US_BULLET_4" | i18n }}
            </h6>
            <h6 class="mb-3">
              <i class="fas fa-check-circle me-2 text-primary"></i>{{ "ABOUT_US_BULLET_5" | i18n }}
            </h6>
            <h6>
              <i class="fas fa-check-circle me-2 text-secondary"></i
              >{{ "ABOUT_US_BULLET_6" | i18n }}
            </h6>
          </div>
        </div>
        <a href="#contact" class="btn btn-primary px-5 py-3 btn-border-radius"
          >{{ "ABOUT_US_BUTTON" | i18n }}</a
        >
      </div>
    </div>
  </div>
</div>
<!-- Modal Video -->
<div
  class="modal fade"
  id="videoModal"
  tabindex="-1"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content rounded-0">
      <div class="modal-header">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="video-modal-frame">
          <video id="video" class="video-modal-player" playsinline muted controls></video>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- About End -->
