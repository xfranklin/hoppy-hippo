<div class="container-fluid footer py-5 wow fadeIn" data-wow-delay="0.1s">
  <div class="container py-2">
    <div class="row g-5">
      <div class="col-md-6 col-lg-4 col-xl-4">
        <div class="footer-item">
          <div class="d-flex align-items-center mb-3">
            <img
              src="/assets/img/top-logo.png"
              alt="Happy Hippo logo"
              class="me-2"
              style="height: 56px"
            />
            <h2 class="text-primary display-6 mb-0">
              Hoppy <span class="text-secondary">Hippo</span>
            </h2>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 col-xl-4">
        <div class="footer-item">
          <h4
            class="text-primary mb-4 border-bottom border-primary border-2 d-inline-block p-2 title-border-radius"
          >
            Contact Us
          </h4>
          <div class="d-flex flex-column align-items-start">
            <a
              href="mailto:{{ site.contact.email }}"
              class="text-start rounded-0 text-body mb-4"
              aria-label="Email {{ site.contact.email }}"
              ><i class="fas fa-envelope text-primary me-2"></i>{{ site.contact.email }}</a
            >
            <a
              href="tel:{{ site.contact.phoneHref }}"
              class="text-start rounded-0 text-body mb-4"
              aria-label="Call {{ site.contact.phoneDisplay }}"
              ><i class="fa fa-phone-alt text-primary me-2"></i>{{ site.contact.phoneDisplay }}</a
            >
            <a href="" class="text-start rounded-0 text-body mb-4"
              ><i class="fa fa-clock text-primary me-2"></i> 24/7 Hours Service</a
            >
            <div class="footer-icon d-flex">
              <a
                class="btn btn-primary btn-sm-square me-3 rounded-circle text-white"
                href="{{ site.social.facebook }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
              >
                <i class="fab fa-facebook-f"></i>
              </a>
              <a
                class="btn btn-primary btn-sm-square me-3 rounded-circle text-white"
                href="{{ site.social.instagram }}"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
              >
                <i class="fab fa-instagram"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container-fluid copyright bg-dark py-4">
  <div class="container">
    <div class="row">
      <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
        <span class="text-light"
          ><a href="#"><i class="fas fa-copyright text-light me-2"></i>Your Site Name</a>, All right
          reserved.</span
        >
      </div>
      <div class="col-md-8 my-auto text-center text-md-end text-white">
        <small class="text-light">
          This site is protected by reCAPTCHA and the Google
          <a class="link-light text-decoration-underline" href="https://policies.google.com/privacy"
            >Privacy Policy</a
          >
          and
          <a class="link-light text-decoration-underline" href="https://policies.google.com/terms"
            >Terms of Service</a
          >
          apply.
        </small>
      </div>
    </div>
  </div>
</div>
